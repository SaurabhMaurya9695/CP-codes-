vector<int> spf;

void sieve(int N) {
    spf.resize(N + 1);

    for (int i = 0; i <= N; i++)
        spf[i] = i;

    for (int i = 2; 1LL * i * i <= N; i++) {
        if (spf[i] == i) { // i is prime
            for (int j = i * i; j <= N; j += i) {
                if (spf[j] == j)
                    spf[j] = i;
            }
        }
    }
}
