vector<int> lp, primes;

void linearSieve(int N) {
    lp.assign(N + 1, 0);

    for (int i = 2; i <= N; i++) {
        if (lp[i] == 0) {
            lp[i] = i;
            primes.push_back(i);
        }

        for (int p : primes) {
            if (p > lp[i] || 1LL * p * i > N)
                break;

            lp[p * i] = p;
        }
    }
}
